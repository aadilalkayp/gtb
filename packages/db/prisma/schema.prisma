datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  founder
  ops_head
  cro
  coach
  skincare_consultant
  fitness_trainer
  styling_consultant
  media
  client
}

enum ClientType {
  groom
  bride
}

enum ClientStatus {
  lead
  converted
  active
  completed
  on_hold
  cancelled
}

enum LeadPhase {
  new
  contacted
  invited
  registered
  plan_selected
  payment_submitted
}

enum ServiceType {
  skincare
  fitness
  styling
}

enum SessionStatus {
  scheduled
  completed
  delayed
  missed
  cancelled
}

enum InstallmentStatus {
  pending
  proof_submitted
  approved
  rejected
  overdue
  waived
}

enum PaymentMethod {
  upi
  bank_transfer
  cash
  other
}

enum AssignmentRole {
  cro
  coach
  skincare_consultant
  fitness_trainer
  styling_consultant
}

enum StylingStatus {
  upcoming
  in_progress
  completed
}

enum FollowUpType {
  weekly_checkin
  payment_reminder
  progress_update
  satisfaction_check
}

enum FollowUpStatus {
  pending
  completed
  overdue
}

enum ExpenseStatus {
  submitted
  approved
  rejected
}

enum DocumentType {
  assessment_form
  skincare_plan
  fitness_plan
  styling_guide
  consultation_notes
  payment_proof
  payment_receipt
  expense_receipt
  client_photo
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum TaskStatus {
  pending
  in_progress
  completed
  cancelled
}

enum ContentStage {
  planned
  shooting
  editing
  review
  posted
}

enum ContentType {
  photo
  video
  reel
  carousel
  story
  blog
}

enum ContentPlatform {
  instagram
  youtube
  facebook
  website
  other
}

enum Campaign {
  gtb
  glow_to_be
  general
}

enum ActivityAction {
  created
  updated
  deleted
  status_changed
}

/// Auth principal for both staff and clients. Linked to a Supabase auth user
/// via authId. Staff rows have a staff role; client rows have role = client and
/// a 1:1 Client profile.
model User {
  id                   String             @id() @default(uuid())
  authId               String?            @unique()
  email                String             @unique()
  name                 String
  phone                String?
  role                 Role
  avatarUrl            String?
  isActive             Boolean            @default(true)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt()
  client               Client?            @relation("ClientUser")
  convertedClients     Client[]           @relation("ConvertedBy")
  assignments          Assignment[]       @relation("StaffAssignments")
  assignmentsMade      Assignment[]       @relation("AssignmentAssigner")
  installmentsApproved Installment[]      @relation("InstallmentApprover")
  consultantRates      ConsultantRate[]
  sessions             Session[]          @relation("ConsultantSessions")
  followUps            FollowUp[]         @relation("CroFollowUps")
  stylingOps           StylingOperation[] @relation("StylistOps")
  tasksAssigned        Task[]             @relation("TaskAssignee")
  tasksCreated         Task[]             @relation("TaskCreator")
  expensesSubmitted    Expense[]          @relation("ExpenseSubmitter")
  expensesApproved     Expense[]          @relation("ExpenseApprover")
  expensesAsPayee      Expense[]          @relation("ExpensePayee")
  documentsUploaded    Document[]         @relation("DocUploader")
  contentItems         ContentItem[]      @relation("ContentOwner")
  notifications        Notification[]     @relation("UserNotifications")
  activityLogs         ActivityLog[]      @relation("ActivityActor")
}

model Client {
  id                 String             @id() @default(uuid())
  clientCode         String             @unique()
  name               String
  phone              String
  email              String
  type               ClientType
  weddingDate        DateTime
  city               String
  status             ClientStatus       @default(lead)
  leadPhase          LeadPhase          @default(new)
  avatarUrl          String?
  notes              String?
  cancellationReason String?
  onHoldReason       String?
  userId             String?            @unique()
  user               User?              @relation("ClientUser", fields: [userId], references: [id])
  leadSourceId       String?
  leadSource         LeadSource?        @relation(fields: [leadSourceId], references: [id])
  convertedById      String?
  convertedBy        User?              @relation("ConvertedBy", fields: [convertedById], references: [id])
  conversionDate     DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt()
  assessment         Assessment?
  clientPlan         ClientPlan?
  assignments        Assignment[]
  sessions           Session[]
  followUps          FollowUp[]
  stylingOps         StylingOperation[]
  documents          Document[]
  expenses           Expense[]
  tasks              Task[]

  @@index([status])
  @@index([type])
  @@index([weddingDate])
}

/// Full onboarding assessment (SRS §6.2). 1:1 with Client.
model Assessment {
  id                  String    @id() @default(uuid())
  clientId            String    @unique()
  client              Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  age                 Int?
  gender              String?
  profilePhotoUrl     String?
  skinType            String?
  skinConcerns        String[]
  skincareRoutine     String?
  allergies           String?
  dermatologicalNotes String?
  heightCm            Int?
  weightKg            Float?
  fitnessLevel        String?
  healthConditions    String?
  dietaryPreference   String?
  fitnessGoals        String[]
  bodyType            String?
  stylePreferences    String[]
  outfitBudgetRange   String?
  colorPreferences    String?
  stylingNotes        String?
  fullBodyPhotoUrl    String?
  facePhotoUrl        String?
  completedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt()
}

model LeadSource {
  id        String   @id() @default(uuid())
  name      String   @unique()
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  clients   Client[]
}

model Plan {
  id               String        @id() @default(uuid())
  name             String
  clientType       ClientType
  durationMonths   Int
  price            Int
  description      String?
  installmentCount Int           @default(1)
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt()
  services         PlanService[]
  clientPlans      ClientPlan[]
}

model PlanService {
  id              String      @id() @default(uuid())
  planId          String
  plan            Plan        @relation(fields: [planId], references: [id], onDelete: Cascade)
  serviceType     ServiceType
  totalSessions   Int
  startOffsetDays Int
  frequencyDays   Int?
  notes           String?
}

/// A client's enrollment in a plan (1:1 — one active plan per client, SRS A9).
model ClientPlan {
  id                String        @id() @default(uuid())
  clientId          String        @unique()
  client            Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  planId            String
  plan              Plan          @relation(fields: [planId], references: [id])
  planNameSnapshot  String
  priceAtEnrollment Int
  durationMonths    Int
  enrolledAt        DateTime      @default(now())
  installments      Installment[]
}

model Installment {
  id                String            @id() @default(uuid())
  clientPlanId      String
  clientPlan        ClientPlan        @relation(fields: [clientPlanId], references: [id], onDelete: Cascade)
  installmentNumber Int
  amount            Int
  dueDate           DateTime
  status            InstallmentStatus @default(pending)
  paymentMethod     PaymentMethod?
  proofDocumentId   String?           @unique()
  proofDocument     Document?         @relation("InstallmentProof", fields: [proofDocumentId], references: [id])
  approvedById      String?
  approvedBy        User?             @relation("InstallmentApprover", fields: [approvedById], references: [id])
  approvedAt        DateTime?
  rejectionReason   String?
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt()

  @@index([status])
  @@index([dueDate])
}

model Assignment {
  id           String         @id() @default(uuid())
  clientId     String
  client       Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  staffId      String
  staff        User           @relation("StaffAssignments", fields: [staffId], references: [id])
  role         AssignmentRole
  assignedById String?
  assignedBy   User?          @relation("AssignmentAssigner", fields: [assignedById], references: [id])
  assignedAt   DateTime       @default(now())
  unassignedAt DateTime?
  isActive     Boolean        @default(true)

  @@index([clientId, isActive])
  @@index([staffId, isActive])
}

model Session {
  id               String            @id() @default(uuid())
  clientId         String
  client           Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  serviceType      ServiceType
  consultantId     String?
  consultant       User?             @relation("ConsultantSessions", fields: [consultantId], references: [id])
  sessionNumber    Int
  scheduledDate    DateTime
  actualDate       DateTime?
  status           SessionStatus     @default(scheduled)
  notes            String?
  rating           Int?
  ratingFeedback   String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt()
  documents        Document[]
  stylingOperation StylingOperation?

  @@index([clientId])
  @@index([consultantId])
  @@index([scheduledDate])
  @@index([status])
}

model FollowUp {
  id            String         @id() @default(uuid())
  clientId      String
  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  croId         String
  cro           User           @relation("CroFollowUps", fields: [croId], references: [id])
  type          FollowUpType
  dueDate       DateTime
  completedDate DateTime?
  status        FollowUpStatus @default(pending)
  notes         String?
  createdAt     DateTime       @default(now())

  @@index([clientId])
  @@index([croId, status])
  @@index([dueDate])
}

model StylingOperation {
  id                     String        @id() @default(uuid())
  clientId               String
  client                 Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sessionId              String?       @unique()
  session                Session?      @relation(fields: [sessionId], references: [id])
  stylistId              String?
  stylist                User?         @relation("StylistOps", fields: [stylistId], references: [id])
  stylingDate            DateTime?
  stylingLocation        String?
  travelRequired         Boolean       @default(false)
  travelDetails          String?
  status                 StylingStatus @default(upcoming)
  consultationDone       Boolean       @default(false)
  consultationDoneAt     DateTime?
  outfitFinalized        Boolean       @default(false)
  outfitFinalizedAt      DateTime?
  accessoriesFinalized   Boolean       @default(false)
  accessoriesFinalizedAt DateTime?
  guideDelivered         Boolean       @default(false)
  guideDeliveredAt       DateTime?
  finalConfirmation      Boolean       @default(false)
  finalConfirmationAt    DateTime?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt()

  @@index([stylingDate])
  @@index([status])
}

model Document {
  id               String       @id() @default(uuid())
  clientId         String
  client           Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type             DocumentType
  fileName         String
  fileUrl          String
  fileSize         Int
  sessionId        String?
  session          Session?     @relation(fields: [sessionId], references: [id])
  uploadedById     String
  uploadedBy       User         @relation("DocUploader", fields: [uploadedById], references: [id])
  createdAt        DateTime     @default(now())
  installmentProof Installment? @relation("InstallmentProof")
  expenseReceipt   Expense?     @relation("ExpenseReceipt")

  @@index([clientId])
  @@index([type])
}

/// Per-session fee for a consultant, optionally specific to a service type.
model ConsultantRate {
  id          String      @id() @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceType ServiceType
  amount      Int
  createdAt   DateTime    @default(now())

  @@unique([userId, serviceType])
}

model ExpenseCategory {
  id        String    @id() @default(uuid())
  name      String    @unique()
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  expenses  Expense[]
}

model Expense {
  id                String          @id() @default(uuid())
  categoryId        String
  category          ExpenseCategory @relation(fields: [categoryId], references: [id])
  title             String
  amount            Int
  date              DateTime
  paidTo            String?
  submittedById     String
  submittedBy       User            @relation("ExpenseSubmitter", fields: [submittedById], references: [id])
  clientId          String?
  client            Client?         @relation(fields: [clientId], references: [id])
  payeeId           String?
  payee             User?           @relation("ExpensePayee", fields: [payeeId], references: [id])
  sessionId         String?
  status            ExpenseStatus   @default(submitted)
  approvedById      String?
  approvedBy        User?           @relation("ExpenseApprover", fields: [approvedById], references: [id])
  approvedAt        DateTime?
  receiptDocumentId String?         @unique()
  receiptDocument   Document?       @relation("ExpenseReceipt", fields: [receiptDocumentId], references: [id])
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt()

  @@index([status])
  @@index([date])
}

model ContentItem {
  id          String          @id() @default(uuid())
  title       String
  contentType ContentType
  campaign    Campaign
  platform    ContentPlatform
  ownerId     String?
  owner       User?           @relation("ContentOwner", fields: [ownerId], references: [id])
  deadline    DateTime?
  status      ContentStage    @default(planned)
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt()

  @@index([status])
}

model Task {
  id           String       @id() @default(uuid())
  title        String
  description  String?
  assignedToId String
  assignedTo   User         @relation("TaskAssignee", fields: [assignedToId], references: [id])
  assignedById String
  assignedBy   User         @relation("TaskCreator", fields: [assignedById], references: [id])
  clientId     String?
  client       Client?      @relation(fields: [clientId], references: [id])
  dueDate      DateTime?
  priority     TaskPriority @default(medium)
  status       TaskStatus   @default(pending)
  createdAt    DateTime     @default(now())
  completedAt  DateTime?

  @@index([assignedToId, status])
}

model Notification {
  id        String   @id() @default(uuid())
  userId    String
  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String?
  linkPath  String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

model ActivityLog {
  id            String         @id() @default(uuid())
  entityType    String
  entityId      String
  action        ActivityAction
  performedById String?
  performedBy   User?          @relation("ActivityActor", fields: [performedById], references: [id])
  summary       String?
  changes       Json?
  createdAt     DateTime       @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}
